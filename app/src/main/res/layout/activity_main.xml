<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FloatMsg 示例"
                android:textColor="#1F2937"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="点击按钮查看不同入场、停留和出场动画。"
                android:textColor="#5B6472"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSlideInLeft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="左侧飞入，原位停留，左侧飞出" />

            <Button
                android:id="@+id/btnSlideInRight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="右侧飞入，原位停留，右侧飞出" />

            <Button
                android:id="@+id/btnLeftCenterOutRight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="左侧飞入，中间停留，右侧飞出" />

            <Button
                android:id="@+id/btnRightCenterOutLeft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="右侧飞入，中间停留，左侧飞出" />

            <Button
                android:id="@+id/btnLeftCenterFade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="左侧飞入，中间停留，中间淡出" />

            <Button
                android:id="@+id/btnRightCenterFade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="右侧飞入，中间停留，中间淡出" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="队列能力示例"
                android:textColor="#1F2937"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="连续入队 3 条" />

            <Button
                android:id="@+id/btnHighPriority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="普通队列 + 高优先级插队" />

            <Button
                android:id="@+id/btnMultiChannel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="两个 channel 同时显示" />

            <Button
                android:id="@+id/btnCancelCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="cancelCurrent：取消当前显示" />

            <Button
                android:id="@+id/btnClearQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="clearQueue：清空等待队列" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/floatContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clickable="false"
        android:focusable="false" />
</FrameLayout>
